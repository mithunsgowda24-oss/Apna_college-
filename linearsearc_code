import java.util.*;
public class arrcc{
public static int linearsearch(int key,int numbers[]){
    
for(int i=0;i<numbers.length;i++){
if (numbers[i]==key){
return i;
}
}
return -1;
}

public static void main(String argos[]){
int numbers[]={1,2,3,4,5,6};
System.out.println("the index of the key is: ");
System.out.println(linearsearch(4,numbers));
}


}
