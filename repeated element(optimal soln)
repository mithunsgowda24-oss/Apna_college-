import java.util.*;
public class arrays{
    public static boolean repeated(int arr[]){
    Arrays.sort(arr); int n=arr.length;
    for(int i=1;i<n;i++){
        if(arr[i]==arr[i-1]){
            return true;
        }
    }
            return false;
    }
    public static void main(String[] args){
        int arr[]={1, 2, 4, 4};
        System.out.println(repeated(arr));
    }

}
